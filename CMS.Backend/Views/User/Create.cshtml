@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.User

<div class="container mt-4">
    <h2 class="text-primary">THÊM THÀNH VIÊN MỚI</h2>
    <hr />

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label asp-for="Username" class="form-label fw-bold"></label>
            <input asp-for="Username" class="form-control" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Password</label>
            <input name="password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-bold"></label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label fw-bold"></label>
            <select asp-for="Role" class="form-control">
                <option value="">-- Chọn quyền --</option>
                <option value="Admin">Quản trị viên</option>
                <option value="Editor">Biên tập viên</option>
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Lưu vào hệ thống</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>