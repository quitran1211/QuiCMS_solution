@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.User

<div class="container mt-4">
    <h2 class="text-warning">CHỈNH SỬA THÀNH VIÊN</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Username" class="form-label fw-bold"></label>
            <input asp-for="Username" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="FullName" class="form-label fw-bold"></label>
            <input asp-for="FullName" class="form-control" />
        </div>

        <!-- ✅ PASSWORD MỚI -->
        <div class="mb-3">
            <label class="form-label fw-bold">Mật khẩu mới</label>
            <input name="newPassword" type="password" class="form-control"
                   placeholder="Để trống nếu không đổi" />
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label fw-bold"></label>
            <select asp-for="Role" class="form-control">
                <option value="Admin">Quản trị viên</option>
                <option value="Editor">Biên tập viên</option>
            </select>
        </div>

        <button type="submit" class="btn btn-warning">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>