@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.OrderDetail

<h2 class="text-primary">THÊM CHI TIẾT ĐƠN HÀNG</h2>

<form asp-action="Create" method="post">

    <!-- ORDER DROPDOWN -->
    <div class="mb-3">
        <label class="form-label fw-bold">Đơn hàng</label>
        <select asp-for="OrderId"
                class="form-control"
                asp-items="ViewBag.Orders">
            <option value="">-- Chọn đơn hàng --</option>
        </select>
    </div>

    <!-- PRODUCT DROPDOWN -->
    <div class="mb-3">
        <label class="form-label fw-bold">Sản phẩm</label>
        <select asp-for="ProductId"
                class="form-control"
                asp-items="ViewBag.Products">
            <option value="">-- Chọn sản phẩm --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Đơn giá</label>
        <input asp-for="UnitPrice" class="form-control" />
    </div>

    <button type="submit" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle"></i> Thêm
    </button>

    <a asp-action="Index" class="btn btn-outline-secondary">
        Quay lại
    </a>

</form>