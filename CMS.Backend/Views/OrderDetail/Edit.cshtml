@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.OrderDetail

<h2 class="text-warning">CẬP NHẬT CHI TIẾT ĐƠN HÀNG</h2>

<form asp-action="Edit" method="post">

    <!-- khóa chính -->
    <input type="hidden" asp-for="OrderId" />
    <input type="hidden" asp-for="ProductId" />

    <!-- ORDER (chỉ hiển thị, không cho sửa nếu bạn dùng khóa kép) -->
    <div class="mb-3">
        <label class="form-label fw-bold">Đơn hàng</label>
        <select class="form-control" disabled>
            <option>Order #@Model.OrderId</option>
        </select>
    </div>

    <!-- PRODUCT (chỉ hiển thị) -->
    <div class="mb-3">
        <label class="form-label fw-bold">Sản phẩm</label>
        <select class="form-control" disabled>
            <option>Product #@Model.ProductId</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Đơn giá</label>
        <input asp-for="UnitPrice" class="form-control" />
    </div>

    <button type="submit" class="btn btn-outline-warning">
        <i class="bi bi-pencil-square"></i> Cập nhật
    </button>

    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>

</form>