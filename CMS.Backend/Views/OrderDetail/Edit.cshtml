@model CMS.Data.Entities.OrderDetail

<h2 class="text-primary">CẬP NHẬT CHI TIẾT ĐƠN HÀNG</h2>

<form asp-action="Edit" method="post">

    <!-- nếu bạn dùng khóa chính kép thì KHÔNG sửa OrderId + ProductId -->
    <input type="hidden" asp-for="OrderId" />
    <input type="hidden" asp-for="ProductId" />

    <div class="mb-2">
        <label>Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Đơn giá</label>
        <input asp-for="UnitPrice" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning mt-2">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Quay lại</a>

</form>