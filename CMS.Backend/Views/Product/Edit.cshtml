@{
    Layout = "_LayoutAdmin";
}
@model CMS.Data.Entities.Product

<h2 class="text-warning">CẬP NHẬT SẢN PHẨM</h2>

<form asp-action="Edit"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label fw-bold"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Danh mục</label>

        <select asp-for="CategoryProductId"
                class="form-select"
                asp-items="ViewBag.Categories">
            <option value="">-- Chọn danh mục --</option>
        </select>

        <span asp-validation-for="CategoryProductId"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label fw-bold"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label fw-bold"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label fw-bold"></label>
        <textarea asp-for="Description"
                  class="form-control"
                  rows="5"></textarea>
    </div>

    <!-- Hiển thị ảnh hiện tại -->
    <div class="mb-3">
        <label class="form-label fw-bold">Ảnh hiện tại</label>
        <br />

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
                <img src="@Model.ImageUrl"
                     width="250"
                     class="img-thumbnail" />
        }
        else
        {
                <p class="text-muted">Chưa có ảnh.</p>
        }
    </div>

    <!-- Upload ảnh mới -->
    <div class="mb-3">
        <label class="form-label fw-bold">
            Chọn ảnh mới
        </label>

        <input type="file"
               name="uploadImage"
               class="form-control"
               accept=".jpg,.jpeg,.png,.gif,.webp" />

        <small class="text-muted">
            Để trống nếu không muốn thay đổi ảnh.
        </small>
    </div>

    <button type="submit"
            class="btn btn-outline-warning">
        <i class="bi bi-pencil-square"></i>
        Cập nhật
    </button>

    <a asp-action="Index"
       class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>

</form>